do\n        if player.Character and player.Character.HumanoidRootPart then\n            player.Character:MoveTo(utilsModule:GetRandomPointOnPart(returnSpawnPartOfMap(map)))\n        end\n    end\nend\n\n-- Setup round\nfunction roundModule:setupRound(testChairNum)\n    local map = mapsModule:cloneInMap(\"Test\", workspace.clonedMaps)\n    setupChairs(testChairNum or #game.Players:GetChildren() + 1, map)\n    setupSpawns(map)\nend\n\nreturn roundModule","name":"Source","valueType":"string"},{"value":[{"value":"3a37d6de-41e6-4519-9dab-34432e77a8c0","name":"_rogit_id","valueType":"string"}],"name":"_attributes","valueType":"_attributes"}]