[{"value":null,"name":"Capabilities","valueType":"SecurityCapabilities"},{"value":"ModuleScript","name":"ClassName","valueType":"string"},{"value":"","name":"LinkedSource","valueType":"string"},{"value":"round","name":"Name","valueType":"string"},{"value":"local roundModule = {}\n\n-- Modules\nlocal chairModule = require(script.Parent.chair)\nlocal utilsModule = require(script.Parent.utils)\n\n-- parent all chairs to parent\nfunction parentAllChairsToParent(parent, chairTable)\n    for _, chair in chairTable do\n        chair.Parent = parent\n    end\nend\n\n-- move the chairs to a random position on a part\nfunction moveChairsToRandomPositionOnPart(partToPos, chairTable)\n    for _, chair in chairTable do\n        chair:MoveTo(utilsModule:GetRandomPointOnPart(partToPos))\n    end\nend\n\n-- clone in a certain amount of chairs (with chairType)\nfunction cloneChairAmount(amountOfChairs, chairType)\n    local chairTable = {}\n    amountOfChairs = (amountOfChairs > 0 and amountOfChairs) or 2\n    for i=1, amountOfChairs do\n        table.insert(chairTable, chairModule:cloneInChair(chairType))\n    end\n    return chairTable\nend\n\n-- Setup the chairs\nfunction setupChairs(amountOfChairs, chairPart, chairType)\n    local chairTable = cloneChairAmount(amountOfChairs, chairType)\n    parentAllChairsToParent(workspace.chairsFolder, chairTable)\n    moveChairsToRandomPositionOnPart(chairPart, chairTable)\nend\n\n-- Setup round\nfunction roundModule:setupRound(testChairNum)\n    -- In the future this would somehow(?) be swapped out for a map w/ multi-parts\n    local chairPart = Instance.new(\"Part\")\n    chairPart.Parent = workspace\n    chairPart.Position = Vector3.new(0,0,5)\n    chairPart.Size = Vector3.new(100,1,100)\n    chairPart.Anchored = true\n    \n    setupChairs(testChairNum or #game.Players:GetChildren() + 1, chairPart)\nend\n\nreturn roundModule","name":"Source","valueType":"string"},{"value":[{"value":"3a37d6de-41e6-4519-9dab-34432e77a8c0","name":"_rogit_id","valueType":"string"}],"name":"_attributes","valueType":"_attributes"}]