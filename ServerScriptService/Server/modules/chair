[{"value":null,"name":"Capabilities","valueType":"SecurityCapabilities"},{"value":"ModuleScript","name":"ClassName","valueType":"string"},{"value":"","name":"LinkedSource","valueType":"string"},{"value":"chair","name":"Name","valueType":"string"},{"value":"--// This handles chair-related things\nlocal ChairsModule = {}\n\nlocal ReplicatedStorage = game:GetService(\"ReplicatedStorage\")\nlocal Players = game:GetService(\"Players\")\nlocal RunService = game:GetService(\"RunService\")\n\n-- Parent for chairs\nlocal chairsFolder = ReplicatedStorage.Chairs\n\nChairsModule.SeatLocks = {\n\n}\n\nChairsModule.Violations = {\n\n}\n\nChairsModule.HumanoidSeated = Instance.new(\"BindableEvent\")\nChairsModule.HumanoidUnseated = Instance.new(\"BindableEvent\")\n\n-- Functions\n\n-- Returns the chair model\nfunction ChairsModule:getChair(customType)\n    return chairsFolder[customType or \"Default\"].Chair\nend\n\n-- Clone in chair model\nfunction ChairsModule:cloneInChair(customType)\n    local chairModel = ChairsModule:getChair(customType):Clone()\n    return chairModel\nend\n\n-- Add a violation\nfunction ChairsModule:addViolation(player)\n    local now = os.clock()\n    local violationData = ChairsModule.Violations[player]\n\n    if not violationData or not violationData.windowStart then\n        ChairsModule.Violations[player] = {\n            count = 1,\n            windowStart = now\n        }\n\n        return 1\n    end\n\n    if now - violationData.windowStart > 10 then\n        ChairsModule.Violations[player] = {\n            count = 1,\n            windowStart = now\n        }\n\n        return 1\n    end\n\n    violationData.count = (violationData.count or 0) + 1\n    return violationData.count\nend\n\n-- clear the seat locks\nfunction ChairsModule:clearSeatLock(player)\n    ChairsModule.SeatLocks[player] = nil\n    ChairsModule.Violations[player] = nil\nend\n\n-- lock player to chair\nfunction ChairsModule:lockPlayerToSeat(player, seat)\n    local character = player.Character\n    local humanoid = character and character:FindFirstChildOfClass(\"Humanoid\")\n\n    if not humanoid or not seat then\n        return\n    end\n\n    ChairsModule.SeatLocks[player] = {\n        seat = seat,\n        locked = true,\n        startedAt = os.clock()\n    }\n\n    humanoid.UseJumpPower = true\n    humanoid.JumpPower = 0\n    humanoid.AutoRotate = false\n    humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, false)\n\n    if humanoid.SeatPart ~= seat or not humanoid.Sit then\n        seat:Sit(humanoid)\n    end\nend\n\n-- releases player from chair\nfunction ChairsModule:releasePlayer(player)\n    local character = player.Character\n    local humanoid = character and character:FindFirstChildOfClass(\"Humanoid\")\n\n    if humanoid then\n        humanoid.JumpPower = 50\n        humanoid.AutoRotate = true\n        humanoid.UseJumpPower = false\n        humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)\n    end\n\n    ChairsModule:clearSeatLock(player)\nend\n\n-- Setup connections\nfunction ChairsModule:setupConnections(chair)\n    chair.Seat:GetPropertyChangedSignal(\"Occupant\"):Connect(function()\n        local humanoid = chair.Seat.Occupant\n\n        if humanoid then\n            local seatedPlayer = Players:GetPlayerFromCharacter(humanoid.Parent)\n\n            if seatedPlayer then\n                print(seatedPlayer.Name)\n                ChairsModule:lockPlayerToSeat(seatedPlayer, chair.Seat)\n                ChairsModule.HumanoidSeated:Fire(humanoid, chair)\n            end\n        else\n            ChairsModule.HumanoidUnseated:Fire(chair)\n        end\n\n        for player, seatData in ChairsModule.SeatLocks do\n            if seatData.seat == chair.Seat then\n                local character = player.Character\n                local playerHumanoid = character and character:FindFirstChildOfClass(\"Humanoid\")\n\n                if playerHumanoid and seatData.locked then\n                    local violations = ChairsModule:addViolation(player)\n\n                    if violations >= 6 then\n                        player:Kick(\"Seat manipulation detected\") -- TODO banAsync\n                        ChairsModule:clearSeatLock(player)\n                        return\n                    end\n                else\n                    ChairsModule:releasePlayer(player)\n                end\n\n            end\n        end\n\n    end)\nend\n\n-- Heartbeat\nRunService.Heartbeat:Connect(function()\n    for player, seatData in ChairsModule.SeatLocks do\n        local character = player.Character\n        local humanoid = character and character:FindFirstChildOfClass(\"Humanoid\")\n        local rootPart = character and character:FindFirstChild(\"HumanoidRootPart\")\n        local seat = seatData.seat\n\n        if not player.Parent or not character or not humanoid or not rootPart or not seat or not seat.Parent then\n            ChairsModule:clearSeatLock(player)\n            continue\n        end\n\n        if not seatData.locked then\n            continue\n        end\n\n        local unauthorizedExit = humanoid.SeatPart ~= seat or not humanoid.Sit\n        local tooFar = (rootPart.Position - seat.Position).Magnitude > 8\n\n        humanoid.JumpPower = 0\n        humanoid.AutoRotate = false\n        humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, false)\n\n        if unauthorizedExit or tooFar then\n            local violations = ChairsModule:addViolation(player)\n\n            rootPart.CFrame = seat.CFrame + Vector3.new(0, 2, 0)\n\n            task.defer(function()\n                if humanoid.Parent and seat.Parent then\n                    seat:Sit(humanoid)\n                end\n            end)\n\n            if violations >= 6 then\n                player:Kick(\"Seat manipulation detected\")\n                ChairsModule:clearSeatLock(player)\n            end\n        end\n    end\nend)\n\n-- Disconnection\nPlayers.PlayerRemoving:Connect(function(player)\n    ChairsModule:clearSeatLock(player)\nend)\n\nreturn ChairsModule","name":"Source","valueType":"string"},{"value":[{"value":"5aac83cc-df9c-4048-9bf7-36302f8845f7","name":"_rogit_id","valueType":"string"}],"name":"_attributes","valueType":"_attributes"}]